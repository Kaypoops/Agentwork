{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install",
    "nixpacksPlan": {
      "providers": ["node"],
      "variables": {
        "NODE_VERSION": "22"
      }
    }
  },
  "deploy": {
    "startCommand": "node backend/server.js",
    "restartPolicyType": "ON_FAILURE"
  }
}